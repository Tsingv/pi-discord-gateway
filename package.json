{
  "name": "piscord",
  "version": "1.5.3",
  "description": "Lightweight Discord gateway for pi coding agent",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Crokily/pi-discord-gateway.git"
  },
  "keywords": [
    "discord",
    "bot",
    "pi",
    "coding-agent",
    "gateway",
    "pi-package"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "piscord": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    ".env.example",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "start": "node dist/cli/index.js start",
    "dev": "tsx src/cli/index.ts start"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "better-sqlite3": "^12.0.0",
    "croner": "^10.0.1",
    "discord.js": "^14.18.0",
    "dotenv": "^16.5.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.77.0",
    "@earendil-works/pi-coding-agent": "^0.77.0",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.2"
  }
}
