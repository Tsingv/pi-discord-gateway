# Generated by: piscord setup
# Or edit manually. See: piscord help

# Required
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# Pi agent configuration
PI_BIN=pi
# direct = spawn pi directly; bash/zsh = run through an interactive login shell
PI_SPAWN_MODE=direct
PI_MODEL=
PI_THINKING=
# Default working directory for pi. Override per channel with:
#   piscord register <id> <name> --cwd /path/to/project
PI_CWD=/home/ubuntu
PI_EXTRA_FLAGS=

# Gateway behavior
MAX_CONCURRENCY=3
POLL_INTERVAL_MS=1000
SHUTDOWN_TIMEOUT_MS=15000
AUTO_REGISTER_DMS=true
MAX_ATTACHMENT_BYTES=26214400
MAX_TOTAL_ATTACHMENT_BYTES=52428800

# Storage examples
# If left unset, the built-in defaults are under ~/.local/share/piscord-gateway/
SESSIONS_DIR=./sessions
DB_PATH=./gateway.db

# Logging
LOG_LEVEL=info
